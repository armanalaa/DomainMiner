# Python cache
__pycache__/
*.pyc
*.pyo

# Logs
logs/
**/logs/

# Large output files — never commit these
*.docx
*.xlsx
*.pdf
*.json
*.bacpac
*.bak
*.db
*.duckdb
*.zip
*.tar.gz
*.txt

# CSV and raw data — too large for GitHub
**/csv/
**/data/
**/knowledge/
**/ccm_output/
**/outputs/
outputs/

# OS junk
.DS_Store
Thumbs.db

# Office lock files
~$*

